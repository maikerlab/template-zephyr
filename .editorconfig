# EditorConfig -- consistent style across editors
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# C sources and headers -- Zephyr uses tabs (tab width 8)
[*.{c,h}]
indent_style = tab
indent_size = 8

# Build / config files
[{CMakeLists.txt,*.cmake}]
indent_style = tab
indent_size = 8

[Makefile]
indent_style = tab
indent_size = 8

# YAML and Kconfig -- spaces
[*.{yml,yaml,conf}]
indent_style = space
indent_size = 2

# Markdown
[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false
